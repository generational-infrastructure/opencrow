# Minimal pi --mode rpc stub for tests: ack each prompt then idle.
# Invoked as `bash testdata/fake-pi` (see PiConfig.BinaryArgs); no exec bit needed.
# shellcheck shell=bash
set -eu
while IFS= read -r line; do
  case "$line" in
    *'"type":"prompt"'*|*'"type": "prompt"'*)
      # When the prompt asks for it, fork a long-lived grandchild and
      # record its PID so the test can verify stopPi reaps the whole
      # process tree, not just the fake-pi leader. Mirrors real pi
      # running a slow bash tool when shutdown arrives.
      case "$line" in
        *spawn-child*)
          sleep 300 &
          printf '%s' "$!" > "$OPENCROW_SESSION_DIR/child.pid"
          ;;
      esac
      printf '%s\n' '{"type":"response","command":"prompt","success":true}'
      printf '%s\n' '{"type":"agent_start"}'
      # When the prompt asks for it, emit a sequence of text_delta
      # message_update events so streaming tests can assert each piece
      # reaches the backend before the agent_end commits the full reply.
      # Each event mirrors pi-mono's real shape: a top-level "message"
      # OBJECT carrying the running assistant message alongside the
      # incremental "assistantMessageEvent". Tests use this to pin the
      # rpcEvent decode contract — a regression that types "message" as
      # a non-RawMessage refuses to decode the line and drops the delta.
      case "$line" in
        *stream-deltas*)
          # Two parallel arrays: delta is the incremental fragment,
          # partial is the cumulative text after that fragment is
          # appended (matches what pi-mono carries in "message.content").
          deltas=('"Hello"' '", "' '"world"' '"!"')
          partials=('"Hello"' '"Hello, "' '"Hello, world"' '"Hello, world!"')
          for i in 0 1 2 3; do
            printf '%s\n' '{"type":"message_update","message":{"role":"assistant","content":[{"type":"text","text":'"${partials[$i]}"'}]},"assistantMessageEvent":{"type":"text_delta","delta":'"${deltas[$i]}"'}}'
          done
          printf '%s\n' '{"type":"agent_end","messages":[{"role":"assistant","content":[{"type":"text","text":"Hello, world!"}],"stopReason":"end_turn"}]}'
          ;;
        *)
          printf '%s\n' '{"type":"agent_end","messages":[{"role":"assistant","content":[{"type":"text","text":"ok"}],"stopReason":"end_turn"}]}'
          ;;
      esac
      ;;
    *'"type":"compact"'*|*'"type": "compact"'*)
      printf '%s\n' '{"type":"response","command":"compact","success":true,"data":{"tokensBefore":1,"summary":"s"}}'
      ;;
    *'"type":"get_available_models"'*|*'"type": "get_available_models"'*)
      printf '%s\n' '{"type":"response","command":"get_available_models","success":true,"data":{"models":[{"provider":"local","id":"qwen3","contextWindow":32768,"reasoning":false},{"provider":"local","id":"gpt-oss","contextWindow":131072,"reasoning":true}]}}'
      ;;
    *'"type":"get_state"'*|*'"type": "get_state"'*)
      # Mirror pi's session state shape. The Active flag in ListModels
      # comes from cross-referencing this against get_available_models,
      # so the first model in the list becomes "active" for tests.
      printf '%s\n' '{"type":"response","command":"get_state","success":true,"data":{"model":{"provider":"local","id":"qwen3","contextWindow":32768,"reasoning":false},"thinkingLevel":"off","isStreaming":false,"isCompacting":false,"steeringMode":"all","followUpMode":"all","sessionId":"s","autoCompactionEnabled":false,"messageCount":0,"pendingMessageCount":0}}'
      ;;
    *'"type":"set_model"'*|*'"type": "set_model"'*)
      # Echo back the requested provider/modelId. The test checks routing,
      # not real registry validation.
      provider=$(printf '%s' "$line" | sed -n 's/.*"provider":"\([^"]*\)".*/\1/p')
      modelid=$(printf '%s' "$line" | sed -n 's/.*"modelId":"\([^"]*\)".*/\1/p')
      printf '%s\n' "{\"type\":\"response\",\"command\":\"set_model\",\"success\":true,\"data\":{\"provider\":\"$provider\",\"id\":\"$modelid\",\"contextWindow\":32768,\"reasoning\":false}}"
      ;;
  esac
done
